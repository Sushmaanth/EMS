@model PaginationViewModel<EmployeeViewModel>

@{
    ViewData["Title"] = "Index";
}
<div class="header-container">
    <h1>Employee List</h1>
    <form asp-action="Index" method="get">
        <div class="d-flex">   
            <input type="text" name="searchText" value="@ViewBag.SearchText" placeholder="Search by ID or Name" class="form-control" />
            <button type="submit" class="border border-0 bg-transparent search-btn"><i class="bi bi-search" style="font-size:24px;"></i></button>
        </div>
    </form>
</div>
<p>
    <a asp-action="Create" asp-controller="Home">Create New</a>
</p>
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle employee-table">
            <thead class="table-dark">
                <tr>
                        <th>Id</th>
                        <th>Name</th>
                        <th>Gender</th>
                        <th>Email</th>
                        <th>Mobile</th>
                        <th>Department</th>
                        <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if(Model != null && Model.Data.Any())
                {
                    @foreach (var item in Model.Data) {
                    <tr class="employee-row"
                        onclick="window.location='@Url.Action("Details", "Home", new { id = item.Id })'">
                        <td>
                            @Html.DisplayFor(modelItem => item.Id)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Name)
                        </td>
                        <td>
                            @Html.DisplayFor(modelItem => item.Gender)
                        </td>

                        <td>
                            @Html.DisplayFor(modelItem => item.EmailId)
                        </td>

                        <td>
                            @Html.DisplayFor(modelItem => item.Mobile)
                        </td>

                        <td>
                            @(item.DepartmentName ?? "No Department")
                        </td>
               
                        <td class="action-cell">
                            <a asp-action="Edit" asp-controller="Home" asp-route-id="@item.Id" class="btn btn-success btn-sm" onclick="event.stopPropagation()">Edit</a>
                                <form asp-action="Delete" asp-controller="Home" asp-route-id="@item.Id" class="delete-form" onclick="event.stopPropagation()">
                                <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                            </form>
                        </td>
                    </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7" class="text-center py-4 text-muted">
                            No Records Found
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        </div>
<nav class="mt-3">
    <ul class="pagination">

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item
                @(Model.PageNumber == i
                                    ? "active"
                                    : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-pageNumber="@i"
                       asp-route-searchText="@ViewBag.SearchText">
                    @i
                </a>
            </li>
        }

    </ul>
</nav>
@if (TempData["SuccessfullyCreatedEmployee"] != null)
{
    <input type="hidden"
           id="successfullyCreatedEmployee"
           value="@TempData["SuccessfullyCreatedEmployee"]" />
}
@if (TempData["employeeUpdateSuccessully"] != null)
{
    <input type="hidden"
           id="employeeUpdateSuccessully"
           value="@TempData["employeeUpdateSuccessully"]" />
}
@if (TempData["DeletedEmployee"] != null)
{
    <input type="hidden"
           id="employeeDeletedSuccessully"
           value="@TempData["DeletedEmployee"]" />
}