@model PaginationViewModel<EmployeeViewModel>

<table class="table table-striped table-hover align-middle employee-table">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Gender</th>
            <th>Email</th>
            <th>Mobile</th>
            <th>Department</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @if (Model != null && Model.Data.Any())
        {
            @foreach (var item in Model.Data)
            {
                <tr class="employee-row"
                    onclick="window.location='@Url.Action("Details", "Home", new { id = item.Id })'">
                    <td>
                        @Html.DisplayFor(modelItem => item.Id)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Name)
                    </td>
                    <td>
                        @Html.DisplayFor(modelItem => item.Gender)
                    </td>

                    <td>
                        @Html.DisplayFor(modelItem => item.EmailId)
                    </td>

                    <td>
                        @Html.DisplayFor(modelItem => item.Mobile)
                    </td>

                    <td>
                        @(item.DepartmentName ?? "No Department")
                    </td>
               
                    <td class="action-cell">
                        <a asp-action="Edit" asp-controller="Home" asp-route-id="@item.Id" class="btn btn-success btn-sm" onclick="event.stopPropagation()">Edit</a>
                        <form asp-action="Delete" asp-controller="Home" asp-route-id="@item.Id" class="delete-form" onclick="event.stopPropagation()">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center py-4 text-muted">
                    No Records Found
                </td>
            </tr>
        }
    </tbody>
</table>

<nav class="mt-3">
    <ul class="pagination">

        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item
                @(Model.PageNumber == i
                                                    ? "active"
                                                    : "")">
                <a class="page-link"
                       asp-action="Index"
                       asp-route-pageNumber="@i"
                       asp-route-searchText="@Model.SearchText"
                       asp-route-pageSize="@Model.PageSize">
                    @i
                </a>
            </li>
        }

    </ul>
</nav>